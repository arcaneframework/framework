#!/bin/sh

BUILD_PATH=@CMAKE_BINARY_DIR@
SOURCE_PATH=@CMAKE_SOURCE_DIR@
AXL_OUTPATH=@SHARE_AXL_DIR@
BINARY_PATH=@BINARY_PATH@
AXLDOC_PATH=@AXLDOC_PATH@

mkdir ${AXL_OUTPATH}
mkdir ${AXL_OUTPATH}/dox
mkdir ${AXL_OUTPATH}/dox/snippets
mkdir ${AXL_OUTPATH}/final_axl

export STDENV_CODE_NAME=Arcane
${BINARY_PATH} launch -arcane_opt arcane_internal

/bin/rm ${AXL_OUTPATH}/final_axl/*.axl
/bin/rm ${AXL_OUTPATH}/dox/*.dox
/bin/rm ${AXL_OUTPATH}/dox/*.md
/bin/rm ${AXL_OUTPATH}/dox/snippets/*.md

${AXLDOC_PATH} --generate-final -a ${BUILD_PATH}/lib/arcane_internal.xml -o ${AXL_OUTPATH}/final_axl ${AXL_OUTPATH}
${AXLDOC_PATH} -u User -a ${AXL_OUTPATH}/final_axl/final_internal.xml -o ${AXL_OUTPATH}/dox ${AXL_OUTPATH}/final_axl/*.axl
