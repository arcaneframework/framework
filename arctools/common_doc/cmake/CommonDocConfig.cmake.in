
function(arcanedoc_initialize_vars doc_type)
  set(COMMON_DOC_DIR "@common_doc_dir@")
  set(COMMON_DOC_INSTALL_DIR "@common_doc_install_dir@")
  if (NOT COMMON_DOC_MATHJAX)
    set(COMMON_DOC_MATHJAX "OFF")
  endif ()
  if (NOT COMMON_DOC_LEGACY_THEME)
    set(COMMON_DOC_LEGACY_THEME "OFF")
  endif ()

  if (${doc_type} STREQUAL "user")
    include(${COMMON_DOC_INSTALL_DIR}/cmake/CommonDocCommonVars.cmake)
    include(${COMMON_DOC_INSTALL_DIR}/cmake/CommonDocUserVars.cmake)
    set(IS_FOR "User")
  elseif (${doc_type} STREQUAL "dev")
    include(${COMMON_DOC_INSTALL_DIR}/cmake/CommonDocCommonVars.cmake)
    include(${COMMON_DOC_INSTALL_DIR}/cmake/CommonDocDevVars.cmake)
    set(IS_FOR "Dev")
  else ()
    message(FATAL_ERROR "Unknown doc type")
  endif ()
endfunction()



function(arcanedoc_initialize_axldoc doc_type executable)
  set(SHARE_AXL_DIR ${CMAKE_BINARY_DIR}/share/axl)
  set(COMMON_DOC_DIR "@common_doc_dir@")
  set(AXLDOC_PATH "@axldoc_path@")
  set(BINARY_PATH "${executable}")

  if (${doc_type} STREQUAL "user")
    set(IS_FOR "User")
  elseif (${doc_type} STREQUAL "dev")
    set(IS_FOR "Dev")
  else ()
    message(FATAL_ERROR "Unknown doc type (${doc_type})")
  endif ()

  if (${COMMON_DOC_LEGACY_THEME} STREQUAL "ON")
    set(AXLDOC_LEGACY "--legacy")
  else ()
    set(AXLDOC_LEGACY "")
  endif ()

  if (UNIX)
    configure_file(${COMMON_DOC_DIR}/generate_axl_infos.sh.in ${CMAKE_BINARY_DIR}/lib/generate_axl_infos_${doc_type}.sh @ONLY)
    add_custom_target(generate_axl_${doc_type} COMMAND "/bin/sh" ${CMAKE_BINARY_DIR}/lib/generate_axl_infos_${doc_type}.sh)
  endif ()
endfunction()


function(arcanedoc_link_axldoc_doxygen doc_type doxygen_target_name)
  if (UNIX)
    add_dependencies(${doxygen_target_name} generate_axl_${doc_type})
  endif ()
endfunction()
