<?xml version="1.0" encoding="utf-8" ?>

<!-- Options for the dataset for the mesh reading test service -->

<service name="MeshReaderUnitTest" version="1.0" type="caseoption" parent-name="Arcane::BasicUnitTest" namespace-name="ArcaneTest">
 <interface name="Arcane::IUnitTest" inherited="false" />

 <options>

  <simple name = "create-edges" type = "bool" default = "false">
    <description>
      Indicates whether edges are created in 3D.
    </description>
  </simple>

  <simple name = "generate-uid-from-nodes-uid" type = "bool" default = "false">
    <description>
      If true, generates the uniqueIds of edges and faces based on those of the nodes.
    </description>
  </simple>

  <simple name = "compact-mesh" type = "bool" default = "false">
    <description>
      Indicates whether the 'compact' and 'compact-after-allocate' properties are applied to the mesh.
    </description>
  </simple>

  <simple name = "swap-nodes-unique-id" type = "bool" default = "false">
    <description>
      Indicates whether the modification of the nodes' uniqueId() is tested.
    </description>
  </simple>

 </options>
</service>
