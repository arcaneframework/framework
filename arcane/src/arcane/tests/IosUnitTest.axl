<?xml version="1.0" ?><!-- -*- SGML -*- -->

<!-- ###################################################################### -->
<!-- ###################################################################### -->

<!-- Data set options for the iOS test service -->

<service name="IosUnitTest" version="1.0" type="caseoption" parent-name="Arcane::BasicUnitTest" namespace-name="ArcaneTest">
  <interface name="Arcane::IUnitTest" inherited="false" />
  <variables>
    <variable field-name="test_cell_variable" name="TestCellVariable" data-type="real" item-kind="cell" dim="0" />
  </variables>
  <options>
    <simple
      name = "output-file-name"
      type = "string"
      default = "iosOutput">
      <name lang='fr'>fichier-sortie</name>
      <description>
	Base name of the output file.
      </description>
    </simple>
 
    <simple
      name = "write-vtu"
      type = "bool"
      default = "true">
      <name lang='fr'>ecriture-vtu</name>
      <description>
	True to save the arcane mesh in a VTU file.
      </description>
    </simple>
    <simple
      name = "write-xmf"
      type = "bool"
      default = "true">
      <name lang='fr'>ecriture-xmf</name>
      <description>
	True to save the arcane mesh in an XMF file.
      </description>
    </simple>
    <simple
      name = "write-msh"
      type = "bool"
      default = "true">
      <name lang='fr'>ecriture-msh</name>
      <description>
	True to save the arcane mesh in an MSH file.
      </description>
    </simple>
    <simple
      name = "write-vtk-legacy"
      type = "bool"
      default = "false">
      <description>
	True to save the arcane mesh in VtkLegacy format
      </description>
    </simple>
  </options>
</service>
