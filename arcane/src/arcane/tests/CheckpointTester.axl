<?xml version="1.0"?><!-- -*- SGML -*- -->

<!-- ###################################################################### -->
<!-- ###################################################################### -->

<!-- Data set options concerning the test module -->

<service name="CheckpointTester" version="1.0" type="caseoption"
  namespace-name="ArcaneTest" parent-name="Arcane::BasicTimeLoopService">
 <description>
  Partial variable test service
 </description>
 <interface name="Arcane::ITimeLoopService" inherited='false'/>
 <options>

  <!-- Number of iterations to perform -->
  <simple
   name = "nb-iteration"
   type = "integer"
   default = "2"
  >
   <description>
Number of iterations to perform
   </description>
  </simple>

  <!-- Protection/recovery service to test -->
  <!-- <simple
   name = "service-name"
   type = "string"
  >
   <description>
Name of the protection service to test
   </description>
  </simple> -->

  <!-- Backup period for rollbacks -->
  <simple
   name = "backward-period"
   type = "integer"
   default = "1"
  >
   <description>
Backup period for rollbacks
   </description>
  </simple>

  <!-- Iteration at which the rollback is triggered -->
  <simple
   name = "backward-iteration"
   type = "integer"
   default = "1"
  >
   <description>
Iteration at which the rollback is triggered
   </description>
  </simple>

 </options>
</service>
