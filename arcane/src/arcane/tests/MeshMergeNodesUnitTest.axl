<?xml version="1.0" ?>

<!-- Dataset options for the node merging service -->

<service name="MeshMergeNodesUnitTest" version="1.0" type="caseoption" parent-name="Arcane::BasicUnitTest" namespace-name="ArcaneTest">
  <interface name="Arcane::IUnitTest" inherited="false" />
  <options>
    <simple name = "nb-node-pair" type = "integer" >
      <description>Number of node pairs to delete</description>
    </simple>
    <simple name = "nb-final-node" type = "integer" >
      <description>Number of nodes after merging</description>
    </simple>
  </options>
</service>
