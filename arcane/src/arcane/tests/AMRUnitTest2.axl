<?xml version="1.0" ?>

<!-- Data set options for the AMR test service -->

<service name="AMRUnitTest2" version="1.0" type="caseoption" parent-name="Arcane::BasicUnitTest" namespace-name="ArcaneTest">
 <interface name="Arcane::IUnitTest" inherited="false" />
 <options>
    <service-instance name    = "format"
                      type    = "Arcane::IPostProcessorWriter"
                      default = "Ensight7PostProcessor"
                      >
      <name lang='fr'>format-service</name>
      <description>
        Specifies the type of library to use for tally outputs.
      </description>
    </service-instance>
 </options>
</service>
