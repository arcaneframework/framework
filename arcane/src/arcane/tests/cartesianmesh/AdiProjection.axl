<?xml version="1.0" ?><!-- -*- SGML -*- -->

<!-- Time step control module options -->
<module name="AdiProjection" xml:space='preserve'>
  <name lang='fr'>projection-adi</name>
  <userclass>User</userclass>
  <description>
    Projection by alternating directions. Ave.
  </description>

  <entry-points>
    <entry-point method-name="cartesianHydroStartInit" name="CartesianHydroStartInit" where="start-init"
                 property="none"/>
    <entry-point method-name="cartesianHydroMain" name="CartesianHydroMain" where="compute-loop" property="none"/>
    <entry-point method-name="copyEulerianCoordinates" name="CopyEulerianCoordinates" where="compute-loop"
                 property="none"/>
  </entry-points>
  <variables>

    <!--   coordinates of the Eulerian mesh nodes (= before Lagrange phase.) -->
    <!--   Lagrange.) -->
    <variable field-name="eulerian_coordinates"
              name="EulerianCoordinates"
              data-type="real3"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!--   coordinates of the nodes after the Lagrange phase. Working table, is -->
    <!--   filled from the mesh. The nodes moved with the velocity -->
    <!--  of grid 0.5(velocity + old_velocity).-->
    <variable field-name="lagrangian_coordinates"
              name="LagrangianCoordinates"
              data-type="real3"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!--  Volume of the cells at the beginning of the time step. -->
    <variable field-name="old_volume"
              name="OldCellVolume"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Nodal velocity at the beginning of the time step. Specific -->
    <!--  predictor/corrector ?? -->
    <variable field-name="old_velocity"
              name="OldVelocity"
              data-type="real3"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Nodal velocity at the end of the time step. Specific -->
    <!--  predictor/corrector ?? -->
    <variable field-name="velocity"
              name="Velocity"
              data-type="real3"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Displacement velocity of the mesh nodes -->
    <variable field-name="lagrangian_velocity"
              name="LagrangianVelocity"
              data-type="real3"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Volume flux for projection (dVol for S1F). Mixed mesh table -->
    <variable field-name="volume_flux_left"
              name="VolumeFluxLeft"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Volume flux for projection (dVol for S1F). Mixed mesh table -->
    <variable field-name="volume_flux_right"
              name="VolumeFluxRight"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Mass flux for projection (dm for S1F). Mixed mesh table -->
    <variable field-name="mass_flux_left"
              name="MassFluxLeft"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Mass flux for projection (dm for S1F). Mixed mesh table -->
    <variable field-name="mass_flux_right"
              name="MassFluxRight"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Dual mass flux for projecting quantities at the nodes (= -->
    <!--  the velocity). -->
    <variable field-name="nodal_mass_flux_left"
              name="NodalMassFluxLeft"
              data-type="real"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Dual mass flux for projecting quantities at the nodes (= -->
    <!--  the velocity). -->
    <variable field-name="nodal_mass_flux_right"
              name="NodalMassFluxRight"
              data-type="real"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- To diagnose a possible mass loss in the nodal mass. -->
    <variable field-name="delta_mass"
              name="DeltaMass"
              data-type="real"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>


    <variable field-name="pressure_gradient"
              name="PressureGradient"
              data-type="real"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>


    <!-- Directional projected volume. Mixed mesh table -->
    <variable field-name="directional_projected_volume"
              name="DirectionalProjectedVolume"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="nrj"
              name="InternalEnergy"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Mass flux for projection (dm for S1F). Mixed mesh table -->
    <variable field-name="directional_internal_energy"
              name="DirectionalInternalEnergy"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <!-- Oriented area -->
    <variable field-name="initial_oriented_area"
              name="InitialOrientedArea"
              data-type="real3"
              item-kind="face"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="face_normal"
              name="FaceNormal"
              data-type="real3"
              item-kind="face"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="face_velocity"
              name="FaceVelocity"
              data-type="real3"
              item-kind="face"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="old_density"
              name="OldDensity"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="pressure"
              name="Pressure"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>


    <variable field-name="density"
              name="Density"
              data-type="real"
              item-kind="cell"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="nodal_density"
              name="NodalDensity"
              data-type="real"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

    <variable field-name="old_nodal_density"
              name="OldNodalDensity"
              data-type="real"
              item-kind="node"
              dim="0"
              dump="true"
              need-sync="true"/>

  </variables>

  <options>

    <simple name="ordre-projection" type="integer" default="1">
      <userclass>User</userclass>
      <description>
        Projection order.
      </description>
    </simple>

  </options>

</module>
