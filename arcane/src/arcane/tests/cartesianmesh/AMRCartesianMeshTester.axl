<?xml version="1.0" ?><!-- -*- SGML -*- -->
<module name="AMRCartesianMeshTester" version="1.0" namespace-name="ArcaneTest">
  <description>
    Test module for the Cartesian mesh manager with AMR
  </description>

  <options>
    <complex name="refinement-2d" type="Refinement2D" minOccurs="0" maxOccurs="unbounded">
      <simple name="position" type="real2"/>
      <simple name="length" type="real2"/>
    </complex>
    <complex name="refinement-3d" type="Refinement3D" minOccurs="0" maxOccurs="unbounded">
      <simple name="position" type="real3"/>
      <simple name="length" type="real3"/>
    </complex>
    <service-instance name="post-processor" type="Arcane::IPostProcessorWriter" default="Ensight7PostProcessor">
      <description>
        Specifies the type of library to use for output processing.
      </description>
    </service-instance>

    <simple name="expected-number-of-cells-in-patchs" type="int32[]">
      <description>
        If not empty, the number of cells that each patch must have
      </description>
    </simple>

    <simple name="expected-number-of-ghost-cells-in-patchs" type="int32[]" optional="true">
      <description>
        If present, the total across all subdomains of the number of ghost cells that each patch must have
      </description>
    </simple>

    <simple name="merge-patches" type="bool" default="true">
      <description>
        Indicates whether to merge patches after refinement/derefinement.
        Allows reducing the number of patches if they are adjacent.
        Only works with amr-type=3.
      </description>
    </simple>

    <simple name="hash-with-ghost" type="bool" default="false">
      <description>
        Should ghost items be included in hash comparisons?
        However, be careful to manage sequential/parallel execution.
      </description>
    </simple>

    <simple name="nodes-uid-hash" type="string">
      <description>Hash of the uniqueId() of the nodes</description>
    </simple>
    <simple name="faces-uid-hash" type="string">
      <description>Hash of the uniqueId() of the faces</description>
    </simple>
    <simple name="cells-uid-hash" type="string">
      <description>Hash of the uniqueId() of the cells</description>
    </simple>
    <simple name="nodes-direction-hash" type="string" default="">
      <description>Hash of the uniqueId() of the nodes including the uniqueId() of surrounding nodes</description>
    </simple>
    <simple name="faces-direction-hash" type="string" default="">
      <description>Hash of the uniqueId() of the faces including the uniqueId() of surrounding cells</description>
    </simple>
    <simple name="cells-direction-hash" type="string" default="">
      <description>Hash of the uniqueId() of the cells including the uniqueId() of surrounding cells</description>
    </simple>
    <simple name="renumber-patch-method" type="integer" default="1">
      <description>
        Patch renumbering method (0, 1, or 2).
      </description>
    </simple>
    <simple name="coarse-at-init" type="bool" default="false">
      <description>
        Indicates if we derefine at initialization
      </description>
    </simple>
    <simple name="verbosity-level" type="int32" default="1">
      <description>
        Verbosity level
      </description>
    </simple>
    <simple name="dump-svg" type="bool" default="true">
      <description>
        Indicates if patches are exported in SVG format
      </description>
    </simple>

    <complex name="coarse-zone-2d" type="CoarseZone2D" minOccurs="0" maxOccurs="unbounded">
      <simple name="position" type="real2">
        <description>
          Indicates the size of the derefinement zone
        </description>
      </simple>
      <simple name="length" type="real2">
        <description>
          Indicates the size of the derefinement zone
        </description>
      </simple>
    </complex>
    <complex name="coarse-zone-3d" type="CoarseZone3D" minOccurs="0" maxOccurs="unbounded">
      <simple name="position" type="real3">
        <description>
          Indicates the size of the derefinement zone
        </description>
      </simple>
      <simple name="length" type="real3">
        <description>
          Indicates the size of the derefinement zone
        </description>
      </simple>
    </complex>

    <complex name="reduce-nb-ghost-layers" type="ReduceNbGhostLayers" minOccurs="0" maxOccurs="unbounded">
      <simple name="level" type="int32">
        <description>
          Indicates the refinement level where layers should be removed.
        </description>
      </simple>
      <simple name="nb-ghost-layers" type="int32">
        <description>
          Indicates the final number of layers.
        </description>
      </simple>
    </complex>

    <simple name="overlap-layer-size-top-level" type="int32" default="-1">
      <description>
        Indicates the number of overlap mesh layers for the highest level (the number
        of layers for lower levels is calculated based on the number of layers of the level
        immediately above).
        Must be even.
        If -1, then no overlap meshes.
      </description>
    </simple>

  </options>

  <entry-points>
    <entry-point method-name="compute" name="compute" where="compute-loop" property="none"/>
    <entry-point method-name="init" name="init" where="init" property="none"/>
    <entry-point method-name="buildInit" name="buildInit" where="build" property="none"/>
  </entry-points>

</module>
