<?xml version="1.0"?><!-- -*- SGML -*- -->

<!-- ###################################################################### -->
<!-- ###################################################################### -->

<!-- Data set options for the AMR test module -->

<module name="AMRTest" version="1.0" namespace-name="ArcaneTest">
  <description>
    AMR test module
  </description>
  
  <variables>
    <variable field-name="data" name="Data" data-type="real" item-kind="cell" dim="0"/>
  </variables>
  
 <options>
   <service-instance name    = "format"
                     type    = "Arcane::IPostProcessorWriter"
                     default = "Ensight7PostProcessor"
                     >
     <name lang='fr'>format-service</name>
     <description>
       Specifies the type of library to use for stripping outputs.
     </description>
   </service-instance>
   <simple name="amr-ratio" type="real" default="1.0">
     <description>Ratio (between 0.0 and 1.0) of the number of meshes to refine</description>
   </simple>
 </options>
</module>
