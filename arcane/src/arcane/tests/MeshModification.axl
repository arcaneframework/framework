<?xml version="1.0" ?>
<service name="MeshModification" version="1.0" type="caseoption" parent-name="Arcane.IUnitTest_WrapperService">

<description>MeshModification service dataset</description>
  <interface name="IUnitTest" inherited='false'/>

  <options>
    <simple name="remove-fraction" type="int32">
      <description>Fraction of cells to remove. If the value is
      2, half of the cells are removed. If the value is 3, we
      remove one third of the cells</description>
    </simple>
  </options>

</service>
