<?xml version="1.0" ?><!-- -*- SGML -*- -->
<!-- Dataset options for the 'SimpleHydroAccelerator' service -->
<service name="SimpleHydroAccelerator" version="1.0" type="caseoption" parent-name="Arcane::BasicUnitTest" namespace-name="SimpleHydro">
  <interface name="SimpleHydro::ISimpleHydroService" />
  <options>
    <simple name = "use-multiple-queue-for-boundary-conditions" type="bool" default="false" >
      <description>Indicates whether multiple execution queues are used per boundary condition</description>
    </simple>
  </options>
</service>
