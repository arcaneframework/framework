<?xml version="1.0" ?>
<service name="MeshMaterialCSharpUnitTest" version="1.0" type="caseoption" parent-name="Arcane.IUnitTest_WrapperService">

<description>Dataset for the MeshMaterialCSharpUnitTest unit test service</description>
  <interface name="IUnitTest" inherited='false'/>

  <options>
    <!-- <simple name="remove-fraction" type="int32">
      <description>Fraction of cells to delete. If the value is 2, half of the cells are deleted. If the value is 3, one third of the cells are deleted</description>
    </simple> -->
  </options>

  <variables>
    <variable
      field-name="mat_density"
      name="Density"
      data-type="real"
      item-kind="cell"
      dim="0"
      dump="true"
      need-sync="true"
      material="true"
      />
    
  </variables>
</service>
