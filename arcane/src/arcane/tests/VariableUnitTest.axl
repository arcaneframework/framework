<?xml version="1.0" ?>

<!-- Dataset options for the variable testing service -->

<service name="VariableUnitTest" version="1.0" type="caseoption" parent-name="Arcane::BasicUnitTest" namespace-name="ArcaneTest">
  <interface name="Arcane::IUnitTest" inherited="false"/>
  <options>

    <!-- Output file for meshes -->
    <simple
      name="nb-reference"
      type="integer"
      default="20"
    >
      <name lang='fr'>nb-reference</name>
      <description>
        Number of references to create for the reference test.
      </description>
    </simple>

    <service-instance name="compressor" type="Arcane::IDataCompressor" optional="true"/>

  </options>
</service>
