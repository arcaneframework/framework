<?xml version="1.0" ?>

<module name="PartialVariableTester" version="1.0">
  <description>Descriptor of the PartialVariableTester module</description>

  <variables />

  <entry-points>
    <entry-point
      method-name="init"
      name="Init"
      where="init"
      property="none"
      />
    <entry-point
      method-name="compute"
      name="Compute"
      where="compute-loop"
      property="none"
      />
  </entry-points>

  <options>
    <simple
      name = "max-iteration"
      type = "integer"
      default = "10"
      >
      <name lang='fr'>max-iteration</name>
      <description>Number of iterations to perform</description>
    </simple>
  </options>

</module>
